# Browser-safe: set separately for local, Preview, staging, and Production.
NEXT_PUBLIC_APP_ENV=
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: never expose to browser code or logs.
SUPABASE_SERVICE_ROLE_KEY=

# Local CLI or approved CI only: never expose to browser code.
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# Vercel CLI or approved CI only; values are supplied by the platform/user.
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=

# Optional non-production smoke-test target; defaults to local when omitted.
PLAYWRIGHT_BASE_URL=
